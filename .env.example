# === LLM API ===
# 프로바이더 선택: anthropic(직접 API) 또는 bedrock(AWS Bedrock) 또는 ollama(로컬 개발)
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# === OpenAI ===
# LLM_PROVIDER=openai 로 설정 시 OpenAI API 사용
# OPENAI_API_KEY=your_openai_api_key

# === Ollama (로컬 개발 전용) ===
# LLM_PROVIDER=ollama 로 설정 시 Ollama 로컬 LLM 사용
# dev/ 폴더에 Ollama 프로바이더 코드가 필요 (docs/OLLAMA_SETUP.md 참고)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT=120

# === LangSmith / LangGraph Studio ===
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=mind-log
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === Database ===
MYSQL_URL=mysql+pymysql://user:password@localhost:3306/mindlog
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# === Vector DB ===
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment

# === KT Cloud RAG Suite ===
# Episode Memory Agent에서 사용하는 KT Cloud API (Query, Passage, TextGen 각각 별도)
# KT_CLOUD_QUERY_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com
# KT_CLOUD_QUERY_TOKEN=your_query_token
# KT_CLOUD_PASSAGE_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com
# KT_CLOUD_PASSAGE_TOKEN=your_passage_token
# KT_CLOUD_TEXTGEN_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com
# KT_CLOUD_TEXTGEN_TOKEN=your_textgen_token
# Episode Memory용 Pinecone 인덱스
# PINECONE_INDEX_EPISODE=mem-podcast-episode

# === Knowledge Agent — KT Cloud RAG Suite ===
# 주의: PARSER(쿼리 전처리)와 PARSE(PDF→MD, Upstage Document Parse)는 서로 다른 API.
#       이름이 한 글자 차이이므로 GitHub Secrets/운영 .env 설정 시 혼동 금지.

# Runtime 검색 경로 (src/agents/podcast/knowledge.py)
# KT_CLOUD_KNOWLEDGE_PARSER_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com/v1/parser
# KT_CLOUD_KNOWLEDGE_PARSER_TOKEN=your_parser_token
# KT_CLOUD_KNOWLEDGE_EMBEDDING_QUERY_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com/v1/embeddings
# KT_CLOUD_KNOWLEDGE_EMBEDDING_QUERY_TOKEN=your_embedding_query_token
# KT_CLOUD_KNOWLEDGE_TEXTGEN_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com/v1/chat/completions
# KT_CLOUD_KNOWLEDGE_TEXTGEN_TOKEN=your_textgen_token

# 적재 스크립트 경로 (scripts/ingest_knowledge.py)
# KT_CLOUD_KNOWLEDGE_PARSE_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com/v1/document-parse
# KT_CLOUD_KNOWLEDGE_PARSE_TOKEN=your_docparse_token
# KT_CLOUD_KNOWLEDGE_EMBEDDING_PASSAGE_ENDPOINT=https://your-endpoint.proxy.aifoundry.ktcloud.com/v1/embeddings
# KT_CLOUD_KNOWLEDGE_EMBEDDING_PASSAGE_TOKEN=your_embedding_passage_token

# Knowledge Agent용 Pinecone 인덱스 (기본: expert-knowledge)
# PINECONE_INDEX_KNOWLEDGE=expert-knowledge

# === Storage ===
AWS_S3_BUCKET=mindlog-images
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-2

# === Storage Mode ===
# local: 모든 DB 직접 접속 (개발)
# proxy: Backend API 경유 (배포)
# hybrid: Pinecone+Neo4j 직접 + MySQL Backend 경유
STORAGE_MODE=local
# S3_MODE=direct  # S3만 별도 모드 (선택, 미설정 시 STORAGE_MODE 따름)

# === Backend API ===
# Backend 서버 (Spring Boot, port 8080) — AI 서버(port 8000)와 별도 애플리케이션
BACKEND_API_URL=http://localhost:8080/api
# NOTE: 아래 타임아웃은 현재 config/settings.yaml에서 관리 (환경변수 미지원)
# BACKEND_API_TIMEOUT=5
# BACKEND_API_LLM_TIMEOUT=30

# === Mode ===
# development | production
APP_ENV=development

# =======================================================
# === AI Team Zone B: Production & Infrastructure Settings ===
# =======================================================
# 운영 환경에서는 아래 값을 .env 파일에 직접 설정하세요
# APP_ENV=production

# 운영 서버 LLM 프로바이더 (AWS Bedrock 권장)
LLM_PROVIDER=bedrock
AWS_REGION=ap-northeast-2

# 보안: 접근 허용 도메인 (Backend 서버 전용 — AI 서버에 직접 접근하는 것은 Backend 서버뿐)
# NOTE: 프론트엔드는 Backend 서버에만 접속하며, AI 서버에 직접 접근하지 않음
# 아래 ALB 주소가 Backend 서버의 오리진인지 인프라 팀과 확인 필요
ALLOWED_ORIGINS=http://<ALB_DOMAIN>

# 로깅 설정 (운영 서버는 JSON 형식 권장)
LOG_FORMAT=json
LOG_LEVEL=info

# 프롬프트 경로 (B-1 전략에 따른 컨테이너 내부 경로)
PROMPT_DIR=/app/prompts